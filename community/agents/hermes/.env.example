# Hermes agent environment variables
# Copy this file to .env and fill in your values

# Required: Telegram bot token from @BotFather
# Leave blank if this agent will only communicate agent-to-agent (no Telegram)
BOT_TOKEN=

# Required if BOT_TOKEN is set: your Telegram user ID (not the bot's)
CHAT_ID=

# Optional: restrict bot to a specific Telegram user ID
ALLOWED_USER=
